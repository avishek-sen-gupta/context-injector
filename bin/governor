#!/usr/bin/env bash
# governor — CLI for Governor v4 (state machine workflow).
# Usage:
#   governor tdd         — activate TDD state machine
#   governor off         — deactivate governor
#   governor status      — show current state
#   governor transition <target> [evidence_key]
#   governor evidence    — show evidence locker
#
# Requires: CLAUDE_SESSION_ID (set by Claude Code), PYTHONPATH, GUVNAH_MACHINES
set -euo pipefail

SESSION="${CLAUDE_SESSION_ID:-}"
if [ -z "$SESSION" ]; then
  echo "Error: CLAUDE_SESSION_ID not set. Run from within Claude Code." >&2
  exit 1
fi

ARGS="${*:-}"
if [ -z "$ARGS" ]; then
  echo "Usage: governor <tdd|off|status|transition|evidence>" >&2
  exit 1
fi

# Build the prompt string the Python module expects
printf '{"prompt": "/governor %s"}' "$ARGS" \
  | python3 -m governor_v4 prompt --session "$SESSION"
