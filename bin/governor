#!/bin/sh
# governor — CLI for the State Machine Governor.
# Usage:
#   governor tdd       — enable governor with TDD machine
#   governor feature   — enable governor with Feature Development machine
#   governor off       — disable the governor
#   governor status    — show current machine and state (JSON)
#   governor <dotted>  — enable with a custom machine class

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SCRIPT_DIR/../hooks/lib/hash.sh"

PLUGIN_DIR="$HOME/.claude/plugins/context-injector"
PROJECT_HASH="$(project_hash "$PWD")"
STATE_DIR="/tmp/ctx-state"
GOVERNOR_DIR="/tmp/ctx-governor"
mkdir -p "$STATE_DIR" "$GOVERNOR_DIR"
LOCK="$GOVERNOR_DIR/$PROJECT_HASH"
ARG="${1:-status}"

case "$ARG" in
  audit)
    shift  # remove 'audit'
    CTX_AUDIT_DIR="${CTX_AUDIT_DIR:-$PWD/.claude/audit}" \
      PYTHONPATH="$PLUGIN_DIR" python3 -m governor audit "$@"
    ;;
  trigger)
    shift  # remove 'trigger'
    EVENT_NAME="$1"
    if [ -z "$EVENT_NAME" ]; then
      echo "Usage: governor trigger <event_name>" >&2
      exit 1
    fi
    # Read machine config
    MACHINE_FILE="$STATE_DIR/$PROJECT_HASH.machine"
    if [ -f "$MACHINE_FILE" ]; then
      CTX_MACHINE="$(cat "$MACHINE_FILE")"
    else
      CTX_MACHINE="machines.tdd.TDD"
    fi
    printf '{"session_id":"cli"}' | \
      CTX_STATE_DIR="$STATE_DIR" CTX_PROJECT_HASH="$PROJECT_HASH" \
      CTX_AUDIT_DIR="${CTX_AUDIT_DIR:-$PWD/.claude/audit}" \
      CTX_MACHINE="$CTX_MACHINE" \
      PYTHONPATH="$PLUGIN_DIR" python3 -m governor trigger "$EVENT_NAME"
    ;;
  lint)
    shift  # remove 'lint'
    PYTHONPATH="$PLUGIN_DIR" python3 -m governor lint "$@"
    ;;
  status)
    CTX_STATE_DIR="$STATE_DIR" CTX_PROJECT_HASH="$PROJECT_HASH" CTX_GOVERNOR_DIR="$GOVERNOR_DIR" \
      PYTHONPATH="$PLUGIN_DIR" python3 -m governor status
    ;;
  off)
    rm -f "$LOCK"
    echo "[governor: off]"
    ;;
  *)
    # Resolve shorthand names
    case "$ARG" in
      tdd)     MACHINE="machines.tdd.TDD" ;;
      feature) MACHINE="machines.feature_development.FeatureDevelopment" ;;
      *)       MACHINE="$ARG" ;;
    esac

    # Write machine config
    printf '%s' "$MACHINE" > "$STATE_DIR/$PROJECT_HASH.machine"

    # Reset state file so the new machine starts fresh
    rm -f "$STATE_DIR/$PROJECT_HASH.json"

    # Enable governor
    touch "$LOCK"

    echo "[governor: on — machine=$MACHINE]"
    ;;
esac
